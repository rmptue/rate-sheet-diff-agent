# Copy to .env and fill in. The pipeline degrades gracefully if these are missing.

# Anthropic — when unset, the AI layer falls back to a deterministic HTML renderer.
ANTHROPIC_API_KEY=

# Email — Gmail API path uses credentials.json + token.json in the repo root.
GMAIL_SENDER=me

# Email — SMTP fallback (Gmail App Password, NOT your account password).
SMTP_USER=
SMTP_APP_PASSWORD=

# Default recipient for the CLI agent.
RECIPIENT_EMAIL=ops@example.com
